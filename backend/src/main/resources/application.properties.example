# ─────────────────────────────────────────────────────────────────────────────
#  DisasterTrain360 AI — Backend Configuration Template
#
#  SETUP:
#    1. Copy this file to application.properties
#       cp application.properties.example application.properties
#    2. Fill in your real values below
#    3. application.properties is git-ignored — never commit it
#
#  FOR DEPLOYMENT (Railway / Render / EC2 / etc.):
#    Set each key as an environment variable in your hosting dashboard.
#    The ${VAR_NAME} syntax reads from the environment automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────
server.port=${PORT:8080}

# ── App ───────────────────────────────────────────────
app.name=DisasterTrain360 AI
app.version=1.0.0

# ── JWT ───────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
app.jwt.secret=${JWT_SECRET}
app.jwt.expiration=86400000

# ── Mock ──────────────────────────────────────────────
app.mock.enabled=false

# ── Spring Cloud AWS ─────────────────────────────────
cloud.aws.region.static=${AWS_DYNAMODB_REGION:ap-south-1}
cloud.aws.credentials.access-key=${AWS_DYNAMODB_ACCESS_KEY}
cloud.aws.credentials.secret-key=${AWS_DYNAMODB_SECRET_KEY}
app.aws.dynamodb.endpoint=
app.aws.bedrock.model.id=amazon.titan-text-express-v1

# ── DynamoDB ──────────────────────────────────────────
# IAM user with AmazonDynamoDBFullAccess policy
aws.dynamodb.region=${AWS_DYNAMODB_REGION:ap-south-1}
aws.dynamodb.access-key=${AWS_DYNAMODB_ACCESS_KEY}
aws.dynamodb.secret-key=${AWS_DYNAMODB_SECRET_KEY}

# ── S3 ────────────────────────────────────────────────
# IAM user with AmazonS3FullAccess policy
aws.s3.region=${AWS_S3_REGION:ap-south-1}
aws.s3.access-key=${AWS_S3_ACCESS_KEY}
aws.s3.secret-key=${AWS_S3_SECRET_KEY}
app.aws.s3.bucket=${AWS_S3_BUCKET:disastertrain360-files}

# ── SNS ───────────────────────────────────────────────
# IAM user with AmazonSNSFullAccess policy
aws.sns.region=${AWS_SNS_REGION:ap-south-1}
aws.sns.access-key=${AWS_SNS_ACCESS_KEY}
aws.sns.secret-key=${AWS_SNS_SECRET_KEY}
app.aws.sns.topic.arn=${AWS_SNS_TOPIC_ARN}

# ── Lambda ────────────────────────────────────────────
# IAM user with AWSLambdaRole policy
aws.lambda.region=${AWS_LAMBDA_REGION:ap-southeast-2}
aws.lambda.access-key=${AWS_LAMBDA_ACCESS_KEY}
aws.lambda.secret-key=${AWS_LAMBDA_SECRET_KEY}
app.aws.lambda.function-name=${AWS_LAMBDA_FUNCTION_NAME:disastertrain360-training-processor}

# ── DynamoDB Table Names ──────────────────────────────
app.dynamo.table.users=users
app.dynamo.table.trainings=trainings
app.dynamo.table.insights=insights
app.dynamo.table.reports=reports
app.dynamo.table.notifications=notifications
app.dynamo.table.enrollments=enrollments

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost:5174}

# ── Swagger ───────────────────────────────────────────
springdoc.api-docs.path=/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operationsSorter=method

# ── Logging ───────────────────────────────────────────
logging.level.com.disastertrain360=DEBUG
logging.level.org.springframework.security=WARN

# ── Multipart (Evidence Upload) ───────────────────────
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=100MB

# ── Actuator (Railway health check) ──────────────────
management.endpoints.web.exposure.include=health
management.endpoint.health.show-details=never
